{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/app_financas?schema=public}\" tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "prisma generate --schema ../prisma/schema.prisma",
    "prisma:push": "prisma db push --schema ../prisma/schema.prisma",
    "prisma:migrate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/app_financas?schema=public}\" prisma migrate dev --schema ../prisma/schema.prisma",
    "prisma:seed": "DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/app_financas?schema=public}\" tsx ../prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "pdfkit": "^0.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.13.9",
    "@types/pdfkit": "^0.17.5",
    "prisma": "^6.16.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

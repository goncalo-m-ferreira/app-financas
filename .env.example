# Variáveis globais opcionais
NODE_ENV=development
PORT=4010
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_financas?schema=public"
# In production use at least 32 characters.
JWT_SECRET="trocar-por-um-segredo-forte-com-32-chars"
JWT_EXPIRES_IN="7d"
FRONTEND_URL="http://localhost:5173"
# Optional: comma-separated list for multiple frontends/previews
# FRONTEND_URLS="https://app.example.com,https://preview.example.com"
AUTH_COOKIE_NAME="app_financas_session"
CSRF_COOKIE_NAME="app_financas_csrf"
COOKIE_SAMESITE="lax"
COOKIE_SECURE="false"
COOKIE_DOMAIN=""
TRUST_PROXY="false"
EMAIL_VERIFICATION_APP_URL="http://localhost:5173/verify-email"
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES="1440"
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS="60"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Production checklist:
# - NODE_ENV=production
# - FRONTEND_URL (or FRONTEND_URLS) must include your real frontend domain (not only localhost)
# - COOKIE_SAMESITE="none"
# - COOKIE_SECURE="true"
# - EMAIL_VERIFICATION_APP_URL="https://app-financas-frontend.vercel.app/verify-email"
# - SMTP_HOST / SMTP_PORT / SMTP_FROM configurados para envio de email
